# =============================================================================
# Atlas LoL — .gitignore
# =============================================================================

# ── Segredos (NUNCA commitar) ─────────────────────────────────────────────────
.env
.env.local
.env.*.local
backend/.env
server/.env

# ── Dependências ──────────────────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
server/node_modules/
client/node_modules/

# ── Build / compilados ────────────────────────────────────────────────────────
dist/
build/
frontend/dist/
client/dist/

# ── Cache de dados brutos ─────────────────────────────────────────────────────
raw_data/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / IDEs / ferramentas locais ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
.claude/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── Cobertura de testes ───────────────────────────────────────────────────────
coverage/
.nyc_output/
