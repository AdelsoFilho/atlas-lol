# =============================================================================
# Atlas LoL — Variáveis de Ambiente
#
# INSTRUÇÕES:
#   1. Copie este arquivo para backend/.env:
#        cp .env.example backend/.env
#   2. Preencha os valores reais em backend/.env
#   3. NUNCA commite backend/.env no git
#
# Onde obter as chaves:
#   RIOT_API_KEY  → https://developer.riotgames.com/  (gratuito, expira em 24h)
#   GROQ_API_KEY  → https://console.groq.com/          (gratuito, tier disponível)
# =============================================================================

# [OBRIGATÓRIO] Chave da Riot Games para acessar a API de partidas
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# [OPCIONAL] Chave da Groq para análise de IA com LLaMA 3.3 70B
# Sem esta chave o botão "Atlas Brain" fica desabilitado — o restante funciona normalmente
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPCIONAL] Porta do servidor Express (padrão: 4000)
PORT=4000

# [OPCIONAL] Ambiente de execução (development | production)
NODE_ENV=development
